# ============================================================
# AGENTE GESTOR DE CORREOS MITUMI
# Basado conceptualmente en Secretario AMPA V3.95
# ============================================================

# Modo general
MODO_DEMO=False
ENVIRONMENT=local

# LLM obligatorio
LLM_ENABLED=True
LLM_PROVIDER=openai_compatible
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=300
LLM_CALL_DELAY_SECONDS=3
LLM_RETRY_MAX_ATTEMPTS=2
LLM_RETRY_BASE_SECONDS=4
LLM_JSON_MODE=False
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Composio / Gmail
COMPOSIO_ENABLED=True
COMPOSIO_API_KEY=
GMAIL_ENABLED=True
GMAIL_ACCOUNT_LABEL=secretario_ampa_pruebas
GMAIL_QUERY=in:inbox is:unread newer_than:7d
GMAIL_MAX_RESULTS=5

# Permisos operativos
ALLOW_CREATE_DRAFTS=True
ALLOW_MARK_AS_READ=True
MARK_READ_AFTER_DRAFT=True
ALLOW_EMAIL_SEND=False
ALLOW_DELETE_EMAIL=False
ALLOW_FORWARD_EMAIL=False
ALLOW_ARCHIVE_EMAIL=False

# Facturación
EMAIL_FACTURACION_DESTINO=

# Salidas y logs
OUTPUTS_DIR=outputs
LOG_LEVEL=INFO
SHOW_STEPS=True
